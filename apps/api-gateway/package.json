{
  "name": "@apps/api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'lint api-gateway: pending eslint setup'",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:seed:plans": "tsx prisma/seed-plans.ts",
    "ops:account-delete:reconcile": "tsx scripts/account-delete-reconcile.ts",
    "ops:audit:retention": "tsx scripts/audit-retention.ts",
    "test:data-dedupe-index": "tsx scripts/data-dedupe-index-check.ts",
    "test:unit": "NODE_ENV=test AUTH_ALLOW_LEGACY_BEARER=true AUTH_LEGACY_DEFAULT_USER_ID=u_1001 AUTH_LEGACY_DEFAULT_TENANT_ID=u_1001 node --test --import tsx test/tasks.service.spec.ts test/compliance.service.spec.ts test/metrics.spec.ts test/task-action.spec.ts test/auth.spec.ts",
    "test:contract": "NODE_ENV=test AUTH_ALLOW_LEGACY_BEARER=true AUTH_LEGACY_DEFAULT_USER_ID=u_1001 AUTH_LEGACY_DEFAULT_TENANT_ID=u_1001 node --test --import tsx test/contract.spec.ts",
    "test:shared-smoke": "tsx scripts/shared-smoke.ts",
    "test:shared-smoke:reset-user": "tsx scripts/reset-local-smoke-user.ts",
    "test:shared-smoke:local-stack": "tsx scripts/shared-smoke-local-stack.ts",
    "test:shared-smoke:media-matrix": "tsx scripts/shared-smoke-media-matrix.ts",
    "test:shared-smoke:doc-native": "bash scripts/shared-smoke-doc-native.sh",
    "test:fe008-admin-smoke": "tsx scripts/fe008-admin-smoke.ts",
    "test:fe008-admin-e2e-lite": "tsx scripts/fe008-admin-e2e-lite.ts",
    "test:fe008-admin-smoke:matrix": "tsx scripts/fe008-admin-smoke-matrix.ts",
    "test:int006-local": "tsx scripts/int006-payment-callback-local.ts",
    "test:shared-smoke:matrix": "tsx scripts/shared-smoke-matrix.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.891.0",
    "@aws-sdk/s3-request-presigner": "^3.891.0",
    "@nestjs/common": "^11.0.7",
    "@nestjs/core": "^11.0.7",
    "@nestjs/platform-fastify": "^11.0.7",
    "@packages/contracts": "workspace:*",
    "@packages/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
