PORT=3000
NODE_ENV=development
# dev|shared|staging|prod
APP_ENV=dev

# Local dev fallback:
# - APP_ENV=dev allows default admin secret behavior.
# Protected envs (shared/staging/prod) MUST set a non-default value.
ADMIN_RBAC_SECRET=replace_with_high_entropy_secret

# Payment callback signature (local mock gateway).
PAYMENT_CALLBACK_SECRET=payment-local-secret
PAYMENT_CALLBACK_REPLAY_WINDOW_SECONDS=300
