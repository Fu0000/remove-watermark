PORT=3000
NODE_ENV=development
# dev|shared|staging|prod
APP_ENV=dev

# Local dev fallback:
# - APP_ENV=dev allows default admin secret behavior.
# Protected envs (shared/staging/prod) MUST set a non-default value.
ADMIN_RBAC_SECRET=replace_with_high_entropy_secret

# Payment callback signature (local mock gateway).
PAYMENT_CALLBACK_SECRET=payment-local-secret
PAYMENT_CALLBACK_REPLAY_WINDOW_SECONDS=300

# Auth
# Production should set AUTH_JWT_SECRET explicitly and keep legacy/unsigned fallback disabled.
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHMS=HS256
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_ALLOW_LEGACY_BEARER=false
AUTH_ALLOW_UNSIGNED_JWT=false
AUTH_ALLOW_DEV_JWT_SECRET=true
AUTH_DEV_JWT_SECRET=dev-jwt-secret-change-me
AUTH_LEGACY_DEFAULT_USER_ID=
AUTH_LEGACY_DEFAULT_TENANT_ID=
