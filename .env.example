NODE_ENV=dev
LOG_LEVEL=info
DB_URL=postgresql://postgres:postgres@localhost:5432/remove_watermark
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remove_watermark
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=miniopassword
MINIO_BUCKET_ASSETS=assets
MINIO_BUCKET_RESULTS=result
MINIO_REGION=us-east-1
MINIO_PRESIGN_ENABLED=true
MINIO_PRESIGN_EXPIRE_SEC=600
ASSET_SOURCE_MODE=minio
TRITON_ENDPOINT=http://localhost:8000
INFERENCE_GATEWAY_URL=http://127.0.0.1:8088
INFERENCE_SHARED_TOKEN=inference-local-token
INFERENCE_MODEL_MODE=mock
INFERENCE_PYTHON_BIN=python3
LAMA_REPO_DIR=/opt/repos/lama
PROPAINTER_REPO_DIR=/opt/repos/propainter
MODEL_LAMA_PATH=/opt/models/lama
MODEL_PROPAINTER_PATH=/opt/models/propainter
INFERENCE_ASSET_DIR=/data/assets
INFERENCE_RESULT_DIR=/data/results
INFERENCE_WORK_DIR=/data/work
INFERENCE_TIMEOUT_IMAGE_SEC=240
INFERENCE_TIMEOUT_VIDEO_SEC=1200
INFERENCE_TIMEOUT_DOC_SEC=300
PROPAINTER_FP16=true
PROPAINTER_SUBVIDEO_LENGTH=80
PROPAINTER_NEIGHBOR_LENGTH=10
PROPAINTER_REF_STRIDE=10
PROPAINTER_RESIZE_RATIO=1.0
LAMA_REFINE=false
FEATURE_IMAGE=true
FEATURE_VIDEO=true
FEATURE_PDF=true
FEATURE_PPT=true
FEATURE_QUALITY_ENABLED=true
AUTH_JWT_SECRET=dev-jwt-secret-change-me
AUTH_JWT_ALGORITHMS=HS256
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_ALLOW_LEGACY_BEARER=false
AUTH_ALLOW_UNSIGNED_JWT=false
AUTH_ALLOW_DEV_JWT_SECRET=true
AUTH_DEV_JWT_SECRET=dev-jwt-secret-change-me
AUTH_LEGACY_DEFAULT_USER_ID=
AUTH_LEGACY_DEFAULT_TENANT_ID=
